{
  "name": "@teamgrid/mcp-server",
  "version": "1.0.0-alpha.3",
  "description": "Optional read-only MCP adapter for the TeamGrid Developer Platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TeamGrid/developer-platform.git",
    "directory": "developer-platform/packages/mcp-server"
  },
  "homepage": "https://github.com/TeamGrid/developer-platform/tree/main/developer-platform/packages/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/TeamGrid/developer-platform/issues"
  },
  "keywords": [
    "teamgrid",
    "api",
    "mcp",
    "model-context-protocol"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "teamgrid-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/bin.js', 0o755)\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.13 <25"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@teamgrid/api-client": "1.0.0-alpha.3",
    "@teamgrid/cli": "1.0.0-alpha.3",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  }
}
