{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "packages/**/*.ts",
      "scripts/staging-load.mjs",
      "scripts/staging-load.test.mjs",
      "scripts/validate-release.mjs",
      "!packages/**/dist/**",
      "!packages/api-client/src/generated/schema.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
