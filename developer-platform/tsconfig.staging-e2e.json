{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strict": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/staging-e2e.mjs",
    "scripts/staging-e2e-evidence.mjs",
    "scripts/staging-load.mjs"
  ]
}
